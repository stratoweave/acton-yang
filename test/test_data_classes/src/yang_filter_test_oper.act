actor DstAdapter(cb: action(?root, ?Exception) -> None):
    def on_update(n: ?yang.gdata.Node, err: ?Exception):
        if err is not None:
            cb(None, err)
            return
        if n is not None:
            cb(root.from_gdata(n), None)
