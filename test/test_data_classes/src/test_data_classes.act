def _test_foo_from_gdata_c1_l1():
    gd = ygdata.Container(children={
        ygdata.Id("http://example.com/foo", "c1"): ygdata.Container(children={
            ygdata.Id("http://example.com/foo", "l1"): ygdata.Leaf("foo-foo"),
            ygdata.Id("http://example.com/bar", "l1"): ygdata.Leaf("foo-bar", ns="http://example.com/bar", module="bar"),
            ygdata.Id("http://example.com/bar", "l2"): ygdata.Leaf("bar", ns="http://example.com/bar", module="bar"),
        })
    })
    # ValueError: Cannot find list child with name li
    d = yang_foo_root.from_gdata(gd)
    return d.to_gdata().prsrc()

