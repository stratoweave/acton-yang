def _test_json_path_conflict_supefluous_namespace_qualifier():
    # `inner` is same-module as `nested`; a body qualified with `foo:inner` is
    # ill-formed under RFC 7951 §4 (only top-level / cross-module members are
    # qualified). The path's last component is used to derive the expected
    # top-level key `foo:inner`, which doesn't match the body below.
    jdb = {
        "inner": {
            "foo": "WINNING"
        }
    }
    try:
        yrestconf.from_json_path(yang_foo.SRC_DNODE, jdb, ["foo:nested", "inner"])
        testing.error("Expected exception on unqualified top-level body key")
    except ValueError:
        pass

def _test_json_path_remove():
    gd2 = yrestconf.from_json_path(yang_foo.SRC_DNODE, {}, ["foo:nested", "inner"], "remove")
    return gd2.prsrc()

def _test_json_path_remove_list_element():
    gd2 = yrestconf.from_json_path(yang_foo.SRC_DNODE, {}, ["foo:nested", "inner", "li1", "AAA"], "remove")
    return gd2.prsrc()

def _test_json_ops():
    ds1 = yjson.from_json(yang_foo.SRC_DNODE, {})
    p1_2 = yrestconf.from_json_path(yang_foo.SRC_DNODE, {"foo:li1": [{"name": "AAA", "bar": "p1"}]}, ["foo:nested", "inner", "li1", "AAA"])
    ds2 = ygdata.patch(ds1, p1_2)
    if ds2 is not None:
        p2_2 = yrestconf.from_json_path(yang_foo.SRC_DNODE, {"foo:li1": [{"name": "BBB", "bar": "p2"}]}, ["foo:nested", "inner", "li1", "BBB"])
        ds3 = ygdata.patch(ds2, p2_2)
        if ds3 is not None:
            p3_2 = yrestconf.from_json_path(yang_foo.SRC_DNODE, {}, ["foo:nested", "inner", "li1", "AAA"], "remove")
            ds4 = ygdata.patch(ds3, p3_2)
            if ds4 is not None:
                return ds4.prsrc()
    return ""

