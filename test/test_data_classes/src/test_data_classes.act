def _test_foo_from_json_full():
    gd2 = yjson.from_json(yang_foo.SRC_DNODE, json_full)
    print(gd2.prsrc(), err=True)
    json_out = gd2.to_yang_jsonstr()
    # This is not entirely in line with RFC 7951, Section 6.1: A value of the
    # "int64", "uint64", or "decimal64" type is represented as a JSON string ...
    # json.encode serializes fixed-size numeric types to numeric literals.
    jdiff = r"""@@ -1,7 +1,7 @@
 {
     "foo:c1": {
         "l1": "foo-foo",
-        "l3": "18446744073709551615",
+        "l3": 18446744073709551615,
         "l_empty": [
             null
         ],
@@ -16,8 +16,8 @@
             }
         ],
         "ll_uint64": [
-            "4",
-            "42"
+            4,
+            42
         ],
         "ll_str": [
             "kava","""
    testing.assertEqual(jdiff, diff.diff(json.encode(json_full, pretty=True), json_out))
    #testing.assertEqual(json.encode(json_full, pretty=True), json_out)
    return gd2.prsrc()

def _test_foo_from_json_empty_leaf():
    json_text = r"""{"foo:c1":{"l_empty":[null]}}"""
    json_in = json.decode(json_text)
    gd2 = yjson.from_json(yang_foo.SRC_DNODE, json_in)
    ad = yang_foo_root.from_gdata(gd2)
    testing.assertNotNone(ad.c1.l_empty)
    l_empty = ad.c1.l_empty
    if l_empty is not None:
        testing.assertTrue(l_empty)
    json_out_text = gd2.to_yang_jsonstr(pretty=False)
    testing.assertEqual(json_text, json_out_text)

