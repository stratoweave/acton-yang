import testing
import yang.gdata as gdata
import yang_filter_test_oper as ft_oper

def _sample_tree() -> gdata.Node:
    data = ft_oper.root(
        system_state=ft_oper.filter_test__system_state(
            clock=ft_oper.filter_test__system_state__clock(
                current_datetime="2026-04-21T10:15:00Z",
                boot_datetime="2026-04-01T00:00:00Z",
            ),
        ),
        interfaces=ft_oper.filter_test__interfaces(),
    )

    eth0 = data.interfaces.interface.create(
        "eth0",
        description="Uplink",
        type="ethernetCsmacd",
        enabled=True,
        admin_status="up",
        oper_status="up",
        last_change="2026-04-20T12:00:00Z",
    )
    eth0.statistics.in_octets = u64(1234)
    eth0.statistics.out_octets = u64(5678)
    eth0.ipv4.mtu = u64(1500)
    eth0.ipv6.mtu = u64(1500)

    eth1 = data.interfaces.interface.create(
        "eth1",
        description="Server",
        type="ethernetCsmacd",
        enabled=False,
        admin_status="down",
        oper_status="lower-layer-down",
        last_change="2026-04-19T07:30:00Z",
    )
    eth1.statistics.in_octets = u64(42)
    eth1.statistics.out_octets = u64(84)
    eth1.ipv4.mtu = u64(9000)
    eth1.ipv6.mtu = u64(9000)

    return data.to_gdata()

def _render_data(node: ?gdata.Node) -> str:
    actual = node!
    return "Filtered gdata tree:\n" + actual.prsrc(deterministic=True) + "\n\n" + "Filtered data XML:\n" + actual.to_xmlstr(deterministic=True)

def _render_subscription(head: str, filt: gdata.FNode) -> str:
    if filt.name is not None:
        filtered = gdata.filter(_sample_tree(), gdata.FNode(children=[filt]))
    else:
        filtered = gdata.filter(_sample_tree(), filt)
    return head + "\n\n" + "NETCONF XML subtree filter:\n" + filt.to_filter_xmlstr(deterministic=True) + "\n\n" + _render_data(filtered)

def _test_subs_raw_clock():
    filt = ft_oper.subs.system_state.clock.filt()!
    return _render_subscription(filt.prsrc(deterministic=True), filt)

def _test_subs_clock_subtree():
    spec = ft_oper.subs.system_state.clock._spec(period=0.05)
    return _render_subscription(str(spec), spec.filt!)

def _test_subs_clock_direct_children():
    spec = ft_oper.subs.system_state.clock._spec(depth=1, period=0.05)
    return _render_subscription(str(spec), spec.filt!)

def _test_subs_system_state_depth_2():
    spec = ft_oper.subs.system_state._spec(depth=2, period=0.05)
    return _render_subscription(str(spec), spec.filt!)

def _test_subs_interface_entry():
    iface = ft_oper.subs.interfaces.interface.entry("eth0")
    spec = iface._spec(period=1.0)
    return _render_subscription(str(spec), spec.filt!)

def _test_subs_interface_entry_depth_2():
    iface = ft_oper.subs.interfaces.interface.entry("eth0")
    spec = iface._spec(depth=2, period=1.0)
    return _render_subscription(str(spec), spec.filt!)

def _test_subs_select_children():
    iface = ft_oper.subs.interfaces.interface.entry("eth0")
    spec = iface._spec(select=[iface.statistics, iface.ipv4], period=1.0)
    return _render_subscription(str(spec), spec.filt!)

def _test_subs_select_children_depth_1():
    iface = ft_oper.subs.interfaces.interface.entry("eth0")
    spec = iface._spec(select=[iface.statistics, iface.ipv4], depth=1, period=1.0)
    return _render_subscription(str(spec), spec.filt!)

def _test_subs_select_mixed_depth_1():
    iface = ft_oper.subs.interfaces.interface.entry("eth0")
    spec = iface._spec(
        select=[iface.statistics.in_octets, iface.ipv4],
        depth=1,
        period=1.0,
    )
    return _render_subscription(str(spec), spec.filt!)

def _test_subs_merge_descendants():
    iface = ft_oper.subs.interfaces.interface.entry("eth0")
    spec = iface._spec(
        select=[iface.statistics.in_octets, iface.statistics.out_octets],
        period=1.0,
    )
    return _render_subscription(str(spec), spec.filt!)

def _test_subs_all_list_elements_leaf():
    spec = ft_oper.subs.interfaces.interface.oper_status._spec(period=1.0)
    return _render_subscription(str(spec), spec.filt!)

def _test_subs_on_change():
    spec = ft_oper.subs.system_state.clock._spec(depth=1)
    return _render_subscription(str(spec), spec.filt!)

def _test_subs_spec_set():
    sub = ft_oper.subs
    iface = sub.interfaces.interface.entry("eth0")
    want: set[gdata.SubscriptionSpec] = set([
        sub.system_state.clock._spec(depth=1, period=0.05),
        iface._spec(select=[iface.statistics, iface.ipv4], period=1.0),
    ])
    return "\n\n".join(sorted([
        _render_subscription(str(spec), spec.filt!)
        for spec in want
    ]))
