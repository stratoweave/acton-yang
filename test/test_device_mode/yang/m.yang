module m {
  namespace "urn:example:m";
  prefix m;
  container cfg {
    leaf name { type string; }
    leaf enabled { type boolean; }
    container sub {
      leaf detail { type string; }
    }
    list items {
      key id;
      leaf id { type string; }
      leaf val { type uint32; }
    }
  }
  rpc ping {
    input  { leaf msg { type string; } }
    output { leaf reply { type string; } }
  }
}
