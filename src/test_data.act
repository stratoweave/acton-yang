      type string;
    }
  }
}"""

    xml_in = r"""<data>
<c1 xmlns="urn:example:y">
  <ll>keep</ll>
  <ll xmlns:nc="urn:ietf:params:xml:ns:netconf:base:1.0" nc:operation="remove">drop</ll>
</c1>
</data>"""

