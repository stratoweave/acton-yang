        Id(NS_acme, "l"): LeafList([LeafListEntryMerge("a"), LeafListEntryMerge("b"), LeafListEntryMerge("c")])
    }, ns="http://example.com/acme", module="acme")

    # new: l = [a, x, c, d]
    # diff would remove "b" and add "x" and "d"
