    p = Container({
        Id("", "l"): Leaf("forty-two"),
        Id("", "ll"): LeafList([LeafListEntryMerge("forty-two")])
    })

    res = patch(old, p)
    exp = Container({
        Id("", "l"): Leaf("forty-two"),
        Id("", "ll"): LeafList([LeafListEntryMerge(u64(42)), LeafListEntryMerge("forty-two")])
    })
    testing.assertEqual(res, exp)

