        raise ValueError("Cannot find leaf-list child with name {name}")

    def get_opt_Identityrefs(self, name) -> list[Identityref]:
        try:
            return self.get_Identityrefs(name)
        except ValueError:
            return []

extension Node(Eq):
    def __eq__(self, other: Node) -> bool:
        if self.ns != other.ns:
            return False

        if isinstance(self, Container) and isinstance(other, Container):
            if set(self.children.keys()) != set(other.children.keys()):
                return False
            for key in self.children.keys():
                if self.children[key] != other.children[key]:
                    return False
            return True

        if isinstance(self, Leaf) and isinstance(other, Leaf):
            return vals_equal(self.val, other.val)

        if isinstance(self, CreateLeaf) and isinstance(other, CreateLeaf):
            return True

        if isinstance(self, ReplaceLeaf) and isinstance(other, ReplaceLeaf):
            return True

        if isinstance(self, LeafList) and isinstance(other, LeafList):
            if len(self.entries) != len(other.entries):
                return False
            if self.user_order != other.user_order:
                return False
            if self.user_order:
                for i in range(len(self.entries)):
                    if self.entries[i] != other.entries[i]:
                        return False
                return True

            # System-ordered: compare as multisets to avoid ordering issues
            for entry in _leaflist_unique_entries(self.entries):
                if self.entries.count(entry) != other.entries.count(entry):
                    return False
            return True

        if isinstance(self, List) and isinstance(other, List):
            if not hack_eq(self.keys, other.keys):
                return False
            if len(self.elements) != len(other.elements):
                return False
            for i in range(len(self.elements)):
                e1 = self.elements[i]
                e2 = other.elements[i]
                if not self.user_order and e1.key_str(self.keys) != e2.key_str(other.keys):
                    for e2 in other.elements:
                        if e1.key_str(self.keys) == e2.key_str(other.keys):
                            break
                if e1 != e2:
                    return False
            return True

        if isinstance(self, Create) and isinstance(other, Create):
            if self.presence != other.presence:
                return False
            if set(self.children.keys()) != set(other.children.keys()):
                return False
            for key in self.children.keys():
                if self.children[key] != other.children[key]:
                    return False
            return True

        if isinstance(self, Replace) and isinstance(other, Replace):
            if self.presence != other.presence:
                return False
            if set(self.children.keys()) != set(other.children.keys()):
                return False
            for key in self.children.keys():
                if self.children[key] != other.children[key]:
                    return False
            return True

        if isinstance(self, Delete) and isinstance(other, Delete):
            if set(self.children.keys()) != set(other.children.keys()):
                return False
            for key in self.children.keys():
                if self.children[key] != other.children[key]:
                    return False
            return True

        if isinstance(self, Absent) and isinstance(other, Absent):
            if set(self.children.keys()) != set(other.children.keys()):
                return False
            for key in self.children.keys():
                if self.children[key] != other.children[key]:
                    return False
            return True

        return False


class List(Node):
    keys: list[Id] # name of the key leafs
    elements: list[Node]
    user_order: bool

    def __init__(self, keys: list[Id], elements: list[Node]=[], user_order=False, ns: ?str=None, module: ?str=None, txid: ?str=None):
        self.keys = keys
        self.elements = elements
        self.user_order = user_order
        self.ns = ns
        self.module = module
        self.txid = txid
        self.children = {}

    @staticmethod
    def from_json(data: value) -> List:
        if isinstance(data, dict):
            node_type = data.get("type")
            if node_type != "List":
                raise ValueError("Invalid gdata node type for List: {node_type}")
            ns, module, txid = node_meta_from_json(data)
            keys: list[Id] = []
            keys_data = data.get("keys")
            if isinstance(keys_data, list):
                for key_data in keys_data:
                    if isinstance(key_data, dict):
                        keys.append(Id.from_json(key_data))
                    else:
                        raise ValueError("Invalid gdata list key encoding: {key_data}")
            elif keys_data is not None:
                raise ValueError("Invalid gdata list keys encoding: {keys_data}")
            elements: list[Node] = []
            elements_data = data.get("elements")
            if isinstance(elements_data, list):
                for element_data in elements_data:
                    if isinstance(element_data, dict):
                        elements.append(Node.from_json(element_data))
                    else:
                        raise ValueError("Invalid gdata list element encoding: {element_data}")
            else:
                raise ValueError("Invalid gdata list elements encoding: {elements_data}")
            user_order = False
            user_order_data = data.get("user_order")
            if isinstance(user_order_data, bool):
                user_order = user_order_data
            return List(keys=keys, elements=elements, user_order=user_order, ns=ns, module=module, txid=txid)
        raise ValueError("Expected dict for List, got {type(data)}")

    def to_json(self) -> dict[str, ?value]:
        result = base_node_json(self, "List")
        result["keys"] = [key.to_json() for key in self.keys]
        if self.user_order:
            result["user_order"] = True
        result["elements"] = [element.to_json() for element in self.elements]
        return result

    def get_opt_list_entry(self, key: str) -> ?Node:
        """Get a list entry by key value

        Returns None if the entry is not found.
        """
        for elem in self.elements:
            if elem.key_str(self.keys) == key:
                return elem
        return None

    def get_list_entry(self, key: str) -> Node:
        """Get a list entry by key value

        Raises ValueError if the entry is not found.
        """
        elem = self.get_opt_list_entry(key)
        if elem is not None:
            return elem
        raise ValueError("Cannot find list entry with key {key}")

class Container(Node):
    def __init__(self, children: dict[Id, Node]={}, presence: bool=False, ns: ?str=None, module: ?str=None, txid: ?str=None):
        self.children = children
        self.presence = presence
        self.ns = ns
        self.module = module
        self.txid = txid

    @staticmethod
    def from_json(data: value) -> Container:
        if isinstance(data, dict):
            node_type = data.get("type")
            if node_type != "Container":
                raise ValueError("Invalid gdata node type for Container: {node_type}")
            ns, module, txid = node_meta_from_json(data)
            presence = False
            presence_data = data.get("presence")
            if isinstance(presence_data, bool):
                presence = presence_data
            return Container(children=node_children_from_json(data), presence=presence, ns=ns, module=module, txid=txid)
        raise ValueError("Expected dict for Container, got {type(data)}")

    def to_json(self) -> dict[str, ?value]:
        result = base_node_json(self, "Container")
        if self.presence:
            result["presence"] = True
        if len(self.children) > 0:
            result["children"] = children_to_json(self.children)
        return result

class Leaf(Node):
    val: value

    def __init__(self, val: value, ns: ?str=None, module: ?str=None, txid: ?str=None):
        self.val = val
        self.ns = ns
        self.module = module
        self.txid = txid
        self.children = {}

    @staticmethod
    def from_json(data: value) -> Leaf:
        if isinstance(data, dict):
            node_type = data.get("type")
            if node_type != "Leaf":
                raise ValueError("Invalid gdata node type for Leaf: {node_type}")
            ns, module, txid = node_meta_from_json(data)
            return Leaf(node_value_from_json(data, "Leaf"), ns=ns, module=module, txid=txid)
        raise ValueError("Expected dict for Leaf, got {type(data)}")

    def to_json(self) -> dict[str, ?value]:
        result = base_node_json(self, "Leaf")
        result["value"] = value_to_json(self.val)
        return result

class LeafList(Node):
    entries: list[LeafListEntry]
    user_order: bool

    def __init__(self, entries: list[LeafListEntry], user_order=False, ns: ?str=None, module: ?str=None, txid: ?str=None):
        self.ns = ns
        self.module = module
        self.user_order = user_order
        self.txid = txid
        self.children = {}
        self.entries = entries

    @staticmethod
    def from_json(data: value) -> LeafList:
        def entry_from_json(data: value) -> LeafListEntry:
            if isinstance(data, dict):
                op = data.get("op")
                value_data = data.get("value")
                if isinstance(op, str) and isinstance(value_data, dict):
                    value = value_from_json(value_data)
                    if op == "merge":
                        return LeafListEntryMerge(value)
                    if op == "remove":
                        return LeafListEntryRemove(value)
                    if op == "create":
                        return LeafListEntryCreate(value)
                    if op == "delete":
                        return LeafListEntryDelete(value)
                    if op == "replace":
                        return LeafListEntryReplace(value)
            raise ValueError("Invalid gdata leaf-list entry encoding: {data}")

        if isinstance(data, dict):
            node_type = data.get("type")
            if node_type != "LeafList":
                raise ValueError("Invalid gdata node type for LeafList: {node_type}")
            ns, module, txid = node_meta_from_json(data)
            entries: list[LeafListEntry] = []
            entries_data = data.get("entries")
            if isinstance(entries_data, list):
                for entry_data in entries_data:
                    if isinstance(entry_data, dict):
                        entries.append(entry_from_json(entry_data))
                    else:
                        raise ValueError("Invalid gdata leaf-list entry encoding: {entry_data}")
            elif entries_data is not None:
                raise ValueError("Invalid gdata leaf-list encoding: {entries_data}")
            user_order = False
            user_order_data = data.get("user_order")
            if isinstance(user_order_data, bool):
                user_order = user_order_data
            return LeafList(entries=entries, user_order=user_order, ns=ns, module=module, txid=txid)
        raise ValueError("Expected dict for LeafList, got {type(data)}")

    def to_json(self) -> dict[str, ?value]:
        def entry_to_json(entry: LeafListEntry) -> dict[str, ?value]:
            if isinstance(entry, LeafListEntryMerge):
                op = "merge"
            elif isinstance(entry, LeafListEntryRemove):
                op = "remove"
            elif isinstance(entry, LeafListEntryCreate):
                op = "create"
            elif isinstance(entry, LeafListEntryDelete):
                op = "delete"
            elif isinstance(entry, LeafListEntryReplace):
                op = "replace"
            else:
                raise ValueError("Unsupported leaf-list entry in serialization: {type(entry)}")
            return {"op": op, "value": value_to_json(entry.val)}

        result = base_node_json(self, "LeafList")
        if self.user_order:
            result["user_order"] = True
        result["entries"] = [entry_to_json(entry) for entry in self.entries]
        return result

class Present:
    """Named type for empty leaf value

    This type is used for the empty leaf value, so that we can do an
    isinstance(v, Present) check to detect when an empty leaf is set. An unset
    empty leaf has the value Absent(). When Acton supports pattern matching we
    can switch to the () identity.
    """
    def __init__(self):
        pass

    def __repr__(self):
        return "Present()"

class Absent(Node):
    """Declarative definition of the absence of a node

    NETCONF remove operation maps to Absent

    Absent is declarative / idempotent, meaning that if the target to be removed
    / made absent is not present, no error is raised.
    """
    def __init__(self, children: dict[Id, Node]={}, ns: ?str=None, module: ?str=None, txid: ?str=None):
        self.ns = ns
        self.module = module
        self.children = children
        self.txid = txid

    @staticmethod
    def from_json(data: value) -> Absent:
        if isinstance(data, dict):
            node_type = data.get("type")
            if node_type != "Absent":
                raise ValueError("Invalid gdata node type for Absent: {node_type}")
            ns, module, txid = node_meta_from_json(data)
            return Absent(children=node_children_from_json(data), ns=ns, module=module, txid=txid)
        raise ValueError("Expected dict for Absent, got {type(data)}")

    def to_json(self) -> dict[str, ?value]:
        result = base_node_json(self, "Absent")
        if len(self.children) > 0:
            result["children"] = children_to_json(self.children)
        return result

class Delete(Node):
    """Imperative delete of a node
    NETCONF delete operation maps to Delete

    Unlike Absent / remove, Delete of a non-existent node is a failure.
    """
    def __init__(self, children: dict[Id, Node]={}, ns: ?str=None, module: ?str=None, txid: ?str=None):
        self.ns = ns
        self.module = module
        self.children = children
        self.txid = txid

    @staticmethod
    def from_json(data: value) -> Delete:
        if isinstance(data, dict):
            node_type = data.get("type")
            if node_type != "Delete":
                raise ValueError("Invalid gdata node type for Delete: {node_type}")
            ns, module, txid = node_meta_from_json(data)
            return Delete(children=node_children_from_json(data), ns=ns, module=module, txid=txid)
        raise ValueError("Expected dict for Delete, got {type(data)}")

    def to_json(self) -> dict[str, ?value]:
        result = base_node_json(self, "Delete")
        if len(self.children) > 0:
            result["children"] = children_to_json(self.children)
        return result

class Create(Node):
    """Imperative create of a node
    NETCONF create operation maps to Create

    Unlike the default implicit merge, Create of an existing node is a failure.
    """
    def __init__(self, children: dict[Id, Node]={}, presence: bool=False, ns: ?str=None, module: ?str=None, txid: ?str=None):
        self.ns = ns
        self.module = module
        self.children = children
        self.presence = presence
        self.txid = txid

    @staticmethod
    def from_json(data: value) -> Create:
        if isinstance(data, dict):
            node_type = data.get("type")
            if node_type != "Create":
                raise ValueError("Invalid gdata node type for Create: {node_type}")
            ns, module, txid = node_meta_from_json(data)
            presence_data = data.get("presence")
            if isinstance(presence_data, bool):
                presence = presence_data
            else:
                presence = False
            return Create(children=node_children_from_json(data), presence=presence, ns=ns, module=module, txid=txid)
        raise ValueError("Expected dict for Create, got {type(data)}")

    def to_json(self) -> dict[str, ?value]:
        result = base_node_json(self, "Create")
        if self.presence:
            result["presence"] = True
        if len(self.children) > 0:
            result["children"] = children_to_json(self.children)
        return result

class CreateLeaf(Create):
    """Imperative create of a leaf (has val)
    NETCONF create operation maps to Create
    """
    val: value
    def __init__(self, val: value, ns: ?str=None, module: ?str=None, txid: ?str=None):
        Create.__init__(self, {}, ns=ns, module=module, txid=txid)
        self.val = val

    @staticmethod
    def from_json(data: value) -> CreateLeaf:
        if isinstance(data, dict):
            node_type = data.get("type")
            if node_type != "CreateLeaf":
                raise ValueError("Invalid gdata node type for CreateLeaf: {node_type}")
            ns, module, txid = node_meta_from_json(data)
            return CreateLeaf(node_value_from_json(data, "CreateLeaf"), ns=ns, module=module, txid=txid)
        raise ValueError("Expected dict for CreateLeaf, got {type(data)}")

    def to_json(self) -> dict[str, ?value]:
        result = base_node_json(self, "CreateLeaf")
        result["value"] = value_to_json(self.val)
        return result

class Replace(Node):
    """Imperative replace of a node
    NETCONF replace operation maps to Replace
    """
    def __init__(self, children: dict[Id, Node]={}, presence: bool=False, ns: ?str=None, module: ?str=None, txid: ?str=None):
        self.ns = ns
