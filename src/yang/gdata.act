def _test_patch_leaflist_remove_missing_idempotent():
    old = Container({
        Id("", "ll"): LeafList([LeafListEntryMerge("a")])
    })

    p = Container({
        Id("", "ll"): LeafList([LeafListEntryRemove("b")])
