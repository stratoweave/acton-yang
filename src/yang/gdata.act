                presence = presence_data
            else:
                presence = False
            return Replace(children=node_children_from_json(data), presence=presence, ns=ns, module=module, txid=txid)
        raise ValueError("Expected dict for Replace, got {type(data)}")

    def to_json(self) -> dict[str, ?value]:
