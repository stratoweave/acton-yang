                    }),
                ], ns=NS_acme, module="acme")
            }, ns=NS_acme, module="acme")
        }).prsrc(deterministic=True)
    )


def _test_filter_merge_keeps_multi_key_list_identity():
    """Merging keyed list predicates should not select cross-product rows."""
    k1 = Id(NS_acme, "k1")
    k2 = Id(NS_acme, "k2")
    payload = Id(NS_acme, "payload")
    pairs = Id(NS_acme, "pairs")
    data = Container({
        pairs: List([k1, k2], [
            Container({
                k1: Leaf("1"),
                k2: Leaf("1"),
                payload: Leaf("11"),
            }),
            Container({
                k1: Leaf("1"),
                k2: Leaf("2"),
                payload: Leaf("12"),
            }),
            Container({
                k1: Leaf("2"),
                k2: Leaf("1"),
                payload: Leaf("21"),
            }),
            Container({
                k1: Leaf("2"),
                k2: Leaf("2"),
                payload: Leaf("22"),
            }),
        ], ns=NS_acme, module="acme"),
    }, ns=NS_acme, module="acme")
    pair_11 = FNode(pairs, children=[
        FNode(k1, value_match="1"),
        FNode(k2, value_match="1"),
        FNode(payload),
    ])
    pair_22 = FNode(pairs, children=[
        FNode(k1, value_match="2"),
        FNode(k2, value_match="2"),
        FNode(payload),
    ])
    filt = FNode(children=filter_merge_list([pair_11, pair_22]))
    res = expect(filter(data, filt), "filter result")
    testing.assertEqual(
        res.prsrc(deterministic=True),
        Container({
            pairs: List([k1, k2], [
                Container({
                    k1: Leaf("1"),
                    k2: Leaf("1"),
                    payload: Leaf("11"),
                }),
                Container({
                    k1: Leaf("2"),
                    k2: Leaf("2"),
                    payload: Leaf("22"),
                }),
            ], ns=NS_acme, module="acme"),
        }, ns=NS_acme, module="acme").prsrc(deterministic=True)
    )


def _test_filter_merge_preserves_subtree_selector():
    """Merging a subtree selector with a descendant should keep the subtree."""
    foo = Id(NS_acme, "foo")
    l = Id(NS_acme, "l")
    name = Id(NS_acme, "name")
    statistics = Id(NS_acme, "statistics")
    in_octets = Id(NS_acme, "in-octets")
    out_octets = Id(NS_acme, "out-octets")
    data = Container({
        foo: Container({
            l: List([name], [
                Container({
                    name: Leaf("eth0"),
                    statistics: Container({
                        in_octets: Leaf(u64(1234)),
                        out_octets: Leaf(u64(5678)),
                    }, ns=NS_acme, module="acme"),
                }),
                Container({
                    name: Leaf("eth1"),
                    statistics: Container({
                        in_octets: Leaf(u64(42)),
                        out_octets: Leaf(u64(84)),
                    }, ns=NS_acme, module="acme"),
                }),
            ], ns=NS_acme, module="acme"),
        }, ns=NS_acme, module="acme"),
    }, ns=NS_acme, module="acme")
    select_statistics = FNode(l, children=[
        FNode(name, value_match="eth0"),
        FNode(statistics),
    ])
    select_statistics_in = FNode(l, children=[
        FNode(name, value_match="eth0"),
        FNode(statistics, children=[
            FNode(in_octets),
        ]),
    ])
    filt = FNode(children=[
        FNode(foo, children=filter_merge_list([select_statistics, select_statistics_in])),
    ])
    res = expect(filter(data, filt), "filter result")
    testing.assertEqual(
        res.prsrc(deterministic=True),
        Container({
            foo: Container({
                l: List([name], [
                    Container({
                        name: Leaf("eth0"),
                        statistics: Container({
                            in_octets: Leaf(u64(1234)),
                            out_octets: Leaf(u64(5678)),
                        }, ns=NS_acme, module="acme"),
                    }),
                ], ns=NS_acme, module="acme"),
            }, ns=NS_acme, module="acme"),
        }, ns=NS_acme, module="acme").prsrc(deterministic=True)
    )


def _test_filter_leaflist_values():
    """Leaf-list content predicates return only matching values."""
    data = Container({
        Id(NS_acme, "foo"): Container({
            Id(NS_acme, "ll"): LeafList([LeafListEntryMerge(u64(1)), LeafListEntryMerge(u64(2)), LeafListEntryMerge(u64(3))]),
            Id(NS_acme, "x"): Leaf(u64(9)),
        }, ns=NS_acme, module="acme"),
        Id(NS_acme, "bar"): Container({
            Id(NS_acme, "b1"): Leaf(u64(7)),
        }, ns=NS_acme, module="acme"),
    })
    filt = FNode(None, None, [
        FNode(Id(NS_acme, "foo"), children=[
            FNode(Id(NS_acme, "ll"), value_match=u64(2)),
            FNode(Id(NS_acme, "ll"), value_match=u64(3)),
        ]),
    ])
    res = expect(filter(data, filt), "filter result")
    # NOTE: Hmm, not entirely sure whether the expected LeafList should contain
    # all elements or just the content-matched ones!? RFC is not super clear...
    testing.assertEqual(
        res.prsrc(deterministic=True),
        Container({
            Id(NS_acme, "foo"): Container({
                Id(NS_acme, "ll"): LeafList([LeafListEntryMerge(u64(2)), LeafListEntryMerge(u64(3))]),
            }, ns=NS_acme, module="acme")
        }).prsrc(deterministic=True)
    )


def _test_filter_wildcard_value_match():
    """Wildcard value match selects list elements by key pattern."""
    k = Id(NS_acme, "name")
    data = Container({
        Id(NS_acme, "foo"): Container({
            Id(NS_acme, "l"): List([k], [
                Container({
                    Id(NS_acme, "name"): Leaf("alpha"),
                    Id(NS_acme, "v"): Leaf(u64(1)),
                }),
                Container({
                    Id(NS_acme, "name"): Leaf("beta"),
                    Id(NS_acme, "v"): Leaf(u64(2)),
                }),
            ], ns=NS_acme, module="acme")
        }, ns=NS_acme, module="acme"),
    })
    filt = FNode(None, None, [
        FNode(Id(NS_acme, "foo"), children=[
            FNode(Id(NS_acme, "l"), children=[
                FNode(Id(NS_acme, "name"), value_match=VWildcard("a*")),
            ]),
        ]),
    ])
    res = expect(filter(data, filt), "filter result")
    testing.assertEqual(
        res.prsrc(deterministic=True),
        Container({
            Id(NS_acme, "foo"): Container({
                Id(NS_acme, "l"): List([k], [
                    Container({
                        Id(NS_acme, "name"): Leaf("alpha"),
                        Id(NS_acme, "v"): Leaf(u64(1)),
                    }),
                ], ns=NS_acme, module="acme")
            }, ns=NS_acme, module="acme")
        }).prsrc(deterministic=True)
    )


