    spec = SubscriptionSpec(None, period=0.05)
    testing.assertEqual(spec.period, u64(50000000))


def _test_subscription_spec_period_int_nanoseconds():
    spec = SubscriptionSpec(None, period=50000000)
    testing.assertEqual(spec.period, u64(50000000))


def _test_subscription_spec_default_on_change():
    spec = SubscriptionSpec(None)
    testing.assertEqual(spec.period, None)


def _test_serialization_roundtrip_leaflist():
    ns_ll = "http://example.com/ll"

    original = Container({
        Id(ns_ll, "strings"): LeafList([
            LeafListEntryMerge("a"),
            LeafListEntryMerge("b"),
            LeafListEntryMerge("c"),
        ], user_order=True),
        Id(ns_ll, "numbers"): LeafList([
            LeafListEntryMerge(1),
            LeafListEntryMerge(2),
            LeafListEntryMerge(3),
        ]),
    }, ns=ns_ll, module="ll")

    return _serde_roundtrip_json(original)


def _test_serialization_roundtrip_special_types():
    ns_special = "http://example.com/special"

    original = Container({
        Id(ns_special, "binary"): Leaf(b"binary data"),
        Id(ns_special, "identity"): Leaf(Identityref("myval", "http://example.com/id", "idmod", "idpfx")),
        Id(ns_special, "empty"): Leaf(Present()),
        Id(ns_special, "counter"): Leaf(u64(18446744073709551615)),
        Id(ns_special, "fraction"): Leaf(Decimal(314, -2)),
    }, ns=ns_special, module="special")

    return _serde_roundtrip_json(original)


def _test_serialization_roundtrip_operations():
    ns_ops = "http://example.com/ops"

    original = Container({
        Id(ns_ops, "create-leaf"): CreateLeaf(u64(7), ns=ns_ops, module="ops"),
        Id(ns_ops, "replace-leaf"): ReplaceLeaf("new-value", ns=ns_ops, module="ops"),
        Id(ns_ops, "entries"): LeafList([
            LeafListEntryMerge("keep"),
            LeafListEntryRemove("drop"),
            LeafListEntryCreate("new"),
            LeafListEntryDelete("gone"),
            LeafListEntryReplace("updated"),
        ], ns=ns_ops, module="ops"),
        Id(ns_ops, "absent"): Absent({
            Id(ns_ops, "child"): Leaf("gone"),
        }, ns=ns_ops, module="ops"),
        Id(ns_ops, "delete"): Delete({
            Id(ns_ops, "child"): Leaf("deleted"),
        }, ns=ns_ops, module="ops"),
        Id(ns_ops, "create"): Create({
            Id(ns_ops, "child"): Leaf(u64(1)),
        }, ns=ns_ops, module="ops"),
        Id(ns_ops, "replace"): Replace({
            Id(ns_ops, "child"): Leaf(True),
        }, ns=ns_ops, module="ops"),
        Id(ns_ops, "create-presence"): Create(presence=True, ns=ns_ops, module="ops"),
        Id(ns_ops, "replace-presence"): Replace(presence=True, ns=ns_ops, module="ops"),
    }, ns=ns_ops, module="ops", txid="tx-ops")

    encoded = _serde_roundtrip_json(original)
    reconstructed = Node.from_json_str(encoded)
    testing.assertTrue(isinstance(reconstructed.children[Id(ns_ops, "create-leaf")], CreateLeaf))
    testing.assertTrue(isinstance(reconstructed.children[Id(ns_ops, "replace-leaf")], ReplaceLeaf))
    entries = reconstructed.get_leaflist(Id(ns_ops, "entries")).entries
    testing.assertTrue(isinstance(entries[0], LeafListEntryMerge))
    testing.assertTrue(isinstance(entries[1], LeafListEntryRemove))
    testing.assertTrue(isinstance(entries[2], LeafListEntryCreate))
    testing.assertTrue(isinstance(entries[3], LeafListEntryDelete))
    testing.assertTrue(isinstance(entries[4], LeafListEntryReplace))


def _test_serialization_roundtrip_complex():
    ns_system = "http://example.com/system"
    ns_network = "http://example.com/network"
    ns_meta = "http://example.com/meta"
    iface_name = Id(ns_network, "name")
    route_dest = Id(ns_network, "destination")

    original = Container({
        Id(ns_network, "config"): Container({
            Id(ns_network, "interfaces"): List([iface_name], [
                Container({
                    iface_name: Leaf("eth0"),
                    Id(ns_network, "ip"): Leaf("192.168.1.1"),
                    Id(ns_network, "mtu"): Leaf(u64(1500)),
                    Id(ns_network, "vlans"): LeafList([
                        LeafListEntryMerge(u64(10)),
                        LeafListEntryMerge(u64(20)),
                        LeafListEntryMerge(u64(30)),
                    ]),
                }),
                Container({
                    iface_name: Leaf("eth1"),
                    Id(ns_network, "ip"): Leaf("192.168.2.1"),
                    Id(ns_network, "mtu"): Leaf(u64(9000)),
                    Id(ns_network, "enabled"): Leaf(True),
                })
            ], user_order=True, ns=ns_network, module="network"),
            Id(ns_network, "routes"): List([route_dest], [
                Container({
                    route_dest: Leaf("0.0.0.0/0"),
                    Id(ns_network, "gateway"): Leaf("192.168.1.254"),
                    Id(ns_network, "metric"): Leaf(100),
                })
            ], ns=ns_network, module="network"),
        }, ns=ns_network, module="network"),
        Id(ns_meta, "metadata"): Container({
            Id(ns_meta, "created"): Leaf("2024-01-01"),
            Id(ns_meta, "version"): Leaf(1),
        }, ns=ns_meta, module="meta"),
    }, ns=ns_system, module="system", txid="tx123")

    return _serde_roundtrip_json(original)
