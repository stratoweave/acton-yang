    }, ns="http://example.com/acme", module="acme")

    res = patch(old, p)
    exp = Container({
        Id(NS_acme, "l"): LeafList([LeafListEntryMerge("a"), LeafListEntryMerge("c"), LeafListEntryMerge("x"), LeafListEntryMerge("d")])
    }, ns="http://example.com/acme", module="acme")

    testing.assertEqual(res, exp)

