"""Generic YANG data parser implementation

This module provides a generic algorithm for parsing YANG data from different
sources (XML, JSON) using the YangData protocol.
"""

import testing

import lib as yang
import gdata as ygdata
import schema as yschema
from identityref import Identityref, PartialIdentityref
from type import Decimal, Ranges
from type import SIGNED_INT_TYPES, UNSIGNED_INT_TYPES


OP_MERGE = "merge"
OP_CREATE = "create"
OP_DELETE = "delete"
OP_REMOVE = "remove"
OP_REPLACE = "replace"


class PathElement:
    """Represents an element in a schema path, with optional key values for lists"""
    node: yschema.DNode
    keys: ?dict[str, value]

    def __init__(self, node: yschema.DNode, keys: ?dict[str, value]=None):
        self.node = node
        self.keys = keys


class YangValidationError(ValueError):
    schema_path: list[PathElement]
    expected_type: yschema.DType
    actual_value: ?value

    def __init__(self, schema_path: list[PathElement], expected_type: yschema.DType, actual_value: ?value):
        self.error_message = ""
        self.schema_path = schema_path
        self.expected_type = expected_type
        self.actual_value = actual_value

    def __str__(self) -> str:
        path_str = format_schema_path(self.schema_path)
        type_str = self.expected_type.format_hint()
        return "Invalid value at {path_str}: '{self.actual_value}' - expected {type_str}"



def format_schema_path(path: list[PathElement]) -> str:
    path_str = ""

    for i, elem in enumerate(path):
        if i > 0:
            prev = path[i-1].node
            if not isinstance(prev, yschema.DRoot):
                path_str = path_str + "/"
            if isinstance(prev, yschema.DNodeInner):
                # TODO: replace with yang.schema.UniqueNamer(prev).unique_name(...) once
                # the Acton compiler stops leaking function mut effect through to callers
                # (which would make format_schema_path mut and break __str__'s purity).
                names = [c.name for c in prev.children]
                conflicts = {n for n in names if names.count(n) > 1}
                name = elem.node.name
                if name in conflicts:
                    name = "{elem.node.prefix}:{name}"
                path_str = path_str + name
                keys_dict = elem.keys
                if keys_dict is not None and len(keys_dict) > 0:
                    predicates = ["{k}='{(v if isinstance(v, str) else str(v)).replace("'", "\\'")}'" for k, v in keys_dict.items()]
                    path_str = path_str + "[" + ",".join(predicates) + "]"
        elif isinstance(elem.node, yschema.DRoot):
            path_str = "/"
        else:
            # Relative path
            path_str = elem.node.name
    return path_str



def fqname(n: yschema.DNode):
    return ygdata.Id(n.namespace, n.name)


def fq_list_keys(l: yschema.DList):
    return [ygdata.Id(l.namespace, k) for k in l.key]


def unwrap_key[T](name: str, val: ?T, spath) -> T:
    if val is not None:
        return val
    raise ValueError("Missing key value at {format_schema_path(spath)}: {name}")


def coerce_integer_value[T(Ord)](raw_value: value, schema_type: yschema.DTypeInteger[T], path: list[PathElement]) -> ?value:
    if isinstance(raw_value, atom):
        builtin_type = schema_type.builtin_type
        if builtin_type in SIGNED_INT_TYPES:
            try:
                return int(raw_value)
            except ValueError:
                pass
        if builtin_type in UNSIGNED_INT_TYPES:
            try:
                return u64(raw_value)
            except ValueError:
                pass


protocol YangData:
    """Protocol for YANG data nodes

    Provides a uniform interface for extracting data from different data formats
    that can carry YANG-modeled data, like XML and JSON
    """
    # TODO: can value implement YangData? Yes, once Acton supports recursive protocol definitions ...
    take_container: mut(yschema.DContainer, str, bool, list[PathElement]) -> ?(op: ?str, val: ?value)
    take_list: mut(yschema.DList, str, bool, list[PathElement]) -> list[(op: ?str, key: dict[str, value], val: value)]
    # Return a typed tuple for leaves. The tuple carries the concrete type name
    # and the parsed value. Missing leaves return None.
    take_leaf: mut(yschema.DRoot, yschema.DLeaf, str, bool, list[PathElement]) -> ?(op: ?str, t: str, val: ?value)
    # For leaf-lists, return a list of typed tuples (op, t, val).
    # For identityref items, val holds a PartialIdentityref.
    take_leaflist: mut(yschema.DRoot, yschema.DLeafList, str, bool, list[PathElement]) -> list[(op: ?str, t: str, val: ?value)]


def user_order(ordered_by):
    return True if ordered_by == "user" else False


def parse_qualified_name(name: str) -> (str, ?str):
    if ":" in name:
        parts = name.split(":", 1)
        return (parts[1], parts[0])
    return (name, None)


def has_mandatory_content(container: yschema.DContainer) -> bool:
    """Return True if a non-presence container has any mandatory content.

    A container has mandatory content if it contains any mandatory leaf, or
    any non-presence child container that itself has mandatory content.
    """
    for c in container.children:
        if isinstance(c, yschema.DLeaf):
            if c.mandatory:
                return True
        elif isinstance(c, yschema.DContainer):
            if not c.presence and has_mandatory_content(c):
                return True
    return False



def from_data[A(YangData)](root: yschema.DRoot, data: A, type_narrower: (?value) -> A, loose: bool=False, root_path: list[str]=[]) -> ygdata.Container:
    """Generic function to convert data to gdata tree based on schema

    Args:
        root: Root schema node (must be the actual root, not an inner node)
        data: Data wrapped in a YangData protocol implementation (XML or JSON)
        loose: Whether to use loose parsing (allows optional fields to be missing)
        root_path: Path from s to the actual data location in the input. This enables
                  partial parsing where the data doesn't start at the schema root but
                  at some inner node. For example, if root_path=["mod:c1", "c2"],
                  the function will navigate from s through c1 and c2 before starting
                  to parse the actual data.

    Returns:
        A yang.gdata.Container containing the parsed data tree
    """
    return from_data_recursive(root, root, data, type_narrower, loose, root_path=root_path, spath=[PathElement(root)])

def from_data_recursive[A(YangData)](root: yschema.DRoot, s: yschema.DNodeInner, data: A, type_narrower: (?value) -> A, loose: bool=False, set_ns: bool=True, root_path: list[str]=[], spath: list[PathElement]=[], skip_nonkeys: bool=False) -> ygdata.Container:
    """Internal function with additional recursion accumulators

    Args:
        root: Root schema node (must be the actual root, not an inner node), e.g. for resolving identityref values
        s: Schema node (container or list) - the root of the schema tree to start parsing from
        data: Data wrapped in a YangData protocol implementation (XML or JSON)
        loose: Whether to use loose parsing (allows optional fields to be missing)
        set_ns: Whether to set namespace information on generated nodes
        root_path: Path from s to the actual data location in the input. This enables
                  partial parsing where the data doesn't start at the schema root but
                  at some inner node. For example, if root_path=["mod:c1", "c2"],
                  the function will navigate from s through c1 and c2 before starting
                  to parse the actual data.
        spath: Accumulated schema path as list[PathElement], including list key
               predicates when descending into list elements. This is passed to
               YangData.take_* so that any validation errors can render full,
               human-friendly paths (e.g., /c1/l2[k1='A']/v1).

    Returns:
        A yang.gdata.Container containing the parsed data tree
    """

    # Navigate to root path if specified
    if root_path != [] and len(spath) -1 < len(root_path):
        next = root_path[len(spath) - 1]

        local_name, module = parse_qualified_name(next)
        child = s.get(local_name, module=module, allow_unqualified=False)
        if isinstance(child, yschema.DNodeInner):
            return from_data_recursive(root, child, data, type_narrower, loose, set_ns, root_path, spath + [PathElement(child)])
        raise ValueError("Node at {format_schema_path(spath + [PathElement(child)])} is not inner: {type(child)}")

    children: dict[ygdata.Id, ygdata.Node] = {}

    unique_namer = yschema.UniqueNamer(s)
    def usname(n) -> str:
        return unique_namer.unique_safe_name(n.name, n.prefix)

    for child in s.children:
        if skip_nonkeys and isinstance(s, yschema.DList) and child.name not in s.key:
            continue

        # Only process data nodes
        if not (isinstance(child, yschema.DNodeLeaf) or isinstance(child, yschema.DContainer) or isinstance(child, yschema.DList)):
            continue

        def path_with_child(k=None):
            return spath + [PathElement(child, k)]

        # Determine namespace (only include if different from parent)
        ns = None
        mod = None
        if child.namespace != s.namespace:
            ns = child.namespace
            mod = child.module

        if isinstance(child, yschema.DContainer):
            opval = data.take_container(child, usname(child), s.namespace != child.namespace, spath)
            if opval is not None:
                val = type_narrower(opval.val)
                cchild = from_data_recursive(root, child, val, type_narrower, loose, set_ns=s.namespace != child.namespace, root_path=root_path, spath=path_with_child())
                cns = child.namespace if set_ns and child.namespace != "" else None
                cmod = child.module if set_ns and child.module != "" else None
                wcchild = None
                if opval.op == OP_REMOVE:
                    wcchild = ygdata.Absent(cchild.children, ns=cns, module=cmod)
                elif opval.op == OP_DELETE:
                    wcchild = ygdata.Delete(cchild.children, ns=cns, module=cmod)
                elif opval.op == OP_CREATE:
                    wcchild = ygdata.Create(cchild.children, presence=cchild.presence, ns=cns, module=cmod)
                elif opval.op == OP_REPLACE:
                    wcchild = ygdata.Replace(cchild.children, presence=cchild.presence, ns=cns, module=cmod)

                if wcchild is not None and not isinstance(wcchild, ygdata.Container):
                    # Absent, Delete, Create, Replace wrappers are not Container and may not have any children
                    children[fqname(child)] = wcchild
                elif isinstance(cchild, ygdata.Container) and (cchild.presence or len(cchild.children) > 0):
                    children[fqname(child)] = cchild
            else:
                # Missing container: if this is a non-presence container and it has
                # mandatory content, then raise an error in strict mode.
                if not loose and isinstance(child, yschema.DContainer) and not child.presence:
                    if has_mandatory_content(child):
                        raise ValueError("Error reading {format_schema_path(path_with_child())}: Cannot find child node with name {child.name}")

        elif isinstance(child, yschema.DList):
            list_val = data.take_list(child, usname(child), s.namespace != child.namespace, spath)
            list_elements = []

            for element in list_val:
                do_skip = True if element.op == OP_REMOVE or element.op == OP_DELETE else False
                element_data = type_narrower(element.val)
                element_gdata = from_data_recursive(root, child, element_data, type_narrower, loose, set_ns=False, root_path=root_path, spath=path_with_child(element.key), skip_nonkeys=do_skip)
                if element.op == OP_REMOVE:
                    list_elements.append(ygdata.Absent(element_gdata.key_children(fq_list_keys(child))))
                elif element.op == OP_DELETE:
                    list_elements.append(ygdata.Delete(element_gdata.key_children(fq_list_keys(child))))
                elif element.op == OP_CREATE:
                    list_elements.append(ygdata.Create(element_gdata.children))
                elif element.op == OP_REPLACE:
                    list_elements.append(ygdata.Replace(element_gdata.children))
                else:
                    list_elements.append(element_gdata)
            if len(list_elements) > 0:
                list_gdata = ygdata.List(fq_list_keys(child), list_elements, user_order=user_order(child.ordered_by), ns=ns, module=mod)
                children[fqname(child)] = list_gdata

        elif isinstance(child, yschema.DLeafList):
            leaflist_val = data.take_leaflist(root, child, usname(child), s.namespace != child.namespace, spath)
            if len(leaflist_val) > 0:
                entries: list[ygdata.LeafListEntry] = []
                for item in leaflist_val:
                    iv = item.val
                    if iv is not None:
                        op = item.op
                        if op == OP_REMOVE:
                            entries.append(ygdata.LeafListEntryRemove(iv))
                        elif op == OP_DELETE:
                            entries.append(ygdata.LeafListEntryDelete(iv))
                        elif op == OP_CREATE:
                            entries.append(ygdata.LeafListEntryCreate(iv))
                        elif op == OP_REPLACE:
                            entries.append(ygdata.LeafListEntryReplace(iv))
                        else:
                            entries.append(ygdata.LeafListEntryMerge(iv))
                if len(entries) == 0 and not yschema.is_optional_arg_yang_leaf(child, yschema.list_keys(s), loose):
                    # Missing leaf-list value
                    raise ValueError("Error reading {format_schema_path(path_with_child())}: Missing non-optional leaf-list value")
                if len(entries) > 0:
                    children[fqname(child)] = ygdata.LeafList(entries, user_order=user_order(child.ordered_by), ns=ns, module=mod)
            elif not yschema.is_optional_arg_yang_leaf(child, yschema.list_keys(s), loose):
                # Missing leaf-list value
                raise ValueError("Error reading {format_schema_path(path_with_child())}: Missing non-optional leaf-list value")

        elif isinstance(child, yschema.DLeaf):
            typed = data.take_leaf(root, child, usname(child), s.namespace != child.namespace, spath)
            if typed is not None:
                wleaf = None
                if typed.op == OP_REMOVE:
                    wleaf = ygdata.Absent()
                elif typed.op == OP_DELETE:
                    wleaf = ygdata.Delete()
                elif typed.op == OP_CREATE:
                    av = typed.val
                    if av is not None:
                        wleaf = ygdata.CreateLeaf(av, ns=ns, module=mod)
                elif typed.op == OP_REPLACE:
                    av = typed.val
                    if av is not None:
                        wleaf = ygdata.ReplaceLeaf(av, ns=ns, module=mod)
                else:
                    av = typed.val
                    if av is not None:
                        wleaf = ygdata.Leaf(av, ns=ns, module=mod)
                if wleaf is not None:
                    children[fqname(child)] = wleaf
            elif not yschema.is_optional_arg_yang_leaf(child, yschema.list_keys(s), loose):
                # Missing leaf value
                raise ValueError("Error reading {format_schema_path(path_with_child())}: Cannot find child node with name {child.name}")
        else:
            raise ValueError(f"Unknown schema node type at {format_schema_path(path_with_child())}: {child}")

    if isinstance(s, yschema.DContainer):
        return ygdata.Container(children, presence=s.presence, ns=s.namespace if set_ns and s.namespace != "" else None, module=s.module if set_ns and s.module != "" else None)
    elif isinstance(s, yschema.DList) or isinstance(s, yschema.DRoot):
        # When processing a list element, return it as a Container
        # The List wrapper is created by the parent when processing all elements
        return ygdata.Container(children)
    elif isinstance(s, yschema.DOutput) or isinstance(s, yschema.DInput):
        return ygdata.Container(children)
    else:
        raise ValueError("Unknown schema node type at {format_schema_path(spath)}: {type(s)}")


def repr_adata(v: value) -> str:
    if ygdata.as_bits(v) is not None:
        return "set({ygdata.repr_gdata(v)})"
    if isinstance(v, ygdata.Present):
        return "True"
    return ygdata.repr_gdata(v)


def pradata(root: yschema.DRoot, node: ygdata.Node, self_name: str="ad", loose: bool=False, root_path: list[str]=[]):
    return _pradata_recursive(root, node, self_name, loose, top=True, root_path=root_path, spath=[PathElement(root)], path_var_names={}, reserved_names=set([self_name]), create_consumed_leaves=set())


def _pradata_recursive(s: yschema.DNodeInner, node: ygdata.Node, self_name: str, loose: bool=False, top: bool=False, list_element: bool=False, root_path: list[str]=[], spath: list[PathElement]=[], path_var_names: dict[str, str], reserved_names: set[str], create_consumed_leaves: set[str]=set()):

    # `path_var_names` maps schema path -> local variable name.
    # `reserved_names` is the set of names already taken in generated code.
    # Same schema path reuses its name; new paths get the next free basename.
    def path_local_var(path_key: str, base_name: str) -> str:
        existing = path_var_names.get(path_key)
        if existing is not None:
            return existing
        # Keep suffixing deterministic per basename and pick the first
        # available candidate (foo, foo_2, foo_3, ...).
        name = base_name
        i = 2
        while name in reserved_names:
            name = "{base_name}_{i}"
            i += 1
        path_var_names[path_key] = name
        reserved_names.add(name)
        return name

    # Navigate to root path if specified
    if root_path != [] and len(spath) - 1 < len(root_path):
        next = root_path[len(spath) - 1]
        local_name, module = parse_qualified_name(next)
        child = s.get(local_name, module=module, allow_unqualified=False)
        if isinstance(child, yschema.DNodeInner):
            return _pradata_recursive(child, node, self_name, loose, top, list_element, root_path, spath + [PathElement(child)], path_var_names, reserved_names, create_consumed_leaves)
        raise ValueError("Node at {format_schema_path(spath + [PathElement(child)])} is not inner: {type(child)}")

    def pname(pe: list[PathElement]):
        return yschema.get_path_name([e.node for e in pe])

    def _find_non_optional_subtree(container: yschema.DNodeInner, spath: list[PathElement], node: ygdata.Node, path: list[str], local_prefix="_") -> (list[str], list[str]):
        r"""Discover the non-optional descendants of a container

        The container here is either a DContainer or a DList (representing
        a list element). We recursively traverse the child nodes of the
        container, looking for non-optional leaves and containers. A
        container is non-optional if it is not a presence container and it
        contains other non-optional nodes.

        As we traverse the tree, we build intermediate container objects
        using their non-optional arguments.

        Args:
            container: The container node to analyze
            path: List of attribute names representing the path from the root
                    to the current container (e.g. ['self', 'child1', 'child2'])
            local_prefix: Prefix used for variable access in generated code,
                            typically "_" for local variables or "" for self references

        The function returns a tuple of two lists:
        - non_optional_args: list of non-optional arguments for the outer container
        - non_optional_containers: list of code lines that declare the
        intermediate containers and their arguments

        Note on f-string evaluation timing:
        This function uses nested f-strings with two evaluation phases:
        1. Generation-time: Outer f-strings resolve class names, paths, variable names
        2. Runtime: Inner f-strings ({{...}}) become {...} and evaluate when pradata() executes.
        """
        non_optional_args = []
        non_optional_containers = []
        unique_namer = yschema.UniqueNamer(container)

        for cchild in container.children:
            def path_with_child():
                return spath + [PathElement(cchild)]

            if not (isinstance(cchild, yschema.DNodeLeaf) or isinstance(cchild, yschema.DContainer) or isinstance(cchild, yschema.DList)):
                continue
            if isinstance(cchild, yschema.DLeaf):
                # The list of children is already sorted so that key leaves
                # come first in the correct order.
                if not yschema.is_optional_arg_yang_leaf(cchild, yschema.list_keys(container), loose):
                    leaf = node.get_leaf(fqname(cchild))
                    non_optional_args.append(repr_adata(leaf.val))
            elif isinstance(cchild, yschema.DContainer):
                if not (cchild.presence or loose or yschema.optional_subtree(cchild)):
                    cchild_safe_name = unique_namer.unique_safe_name(cchild.name, cchild.prefix)

                    # Recursively build subtree for non-optional children
                    sub_args, sub_containers = _find_non_optional_subtree(cchild, path_with_child(), node.get_cnt(fqname(cchild)), path + [cchild_safe_name], local_prefix)

                    # Create variable declaration for this container
                    mcchild_var = path_local_var(pname(path_with_child()), "{'_'.join(path)}_{cchild_safe_name}")

                    if sub_args:
                        sub_args_str = ", ".join(sub_args)
                        non_optional_containers.append("{mcchild_var} = {pname(path_with_child())}({sub_args_str})")
                    else:
                        non_optional_containers.append("{mcchild_var} = {pname(path_with_child())}()")

                    # Add nested variable declarations
                    non_optional_containers.extend(sub_containers)

                    non_optional_args.append(mcchild_var)

        return non_optional_args, non_optional_containers

    def _find_direct_optional_leaf_create_args(container: yschema.DNodeInner, node: ygdata.Node) -> (list[str], set[str]):
        """Collect direct optional DLeaf kwargs accepted by create*()

        Unlike _find_non_optional_subtree(), this only inspects direct DLeaf
        children because create*() do not accept nested optional descendants.
        """
        optional_leaf_args = []
        create_consumed_leaf_args = set()
        unique_namer = yschema.UniqueNamer(container)

        for cchild in container.children:
            if isinstance(cchild, yschema.DLeaf):
                if not yschema.is_optional_arg_yang_leaf(cchild, yschema.list_keys(container), loose):
                    continue

                cchild_arg = unique_namer.unique_safe_name(cchild.name, cchild.prefix)
                leaf = node.get_opt_leaf_or_absent(fqname(cchild))
                if isinstance(leaf, ygdata.Leaf):
                    optional_leaf_args.append("{cchild_arg}={repr_adata(leaf.val)}")
                    create_consumed_leaf_args.add(cchild_arg)
                elif isinstance(leaf, ygdata.Absent):
                    optional_leaf_args.append("{cchild_arg}=False")
                    create_consumed_leaf_args.add(cchild_arg)

        return optional_leaf_args, create_consumed_leaf_args

    unique_namer = yschema.UniqueNamer(s)
    def usname(n) -> str:
        return unique_namer.unique_safe_name(n.name, n.prefix)
    res = []
    if top:
        res.append('# Top node: {format_schema_path(spath)}')
        # Build constructor arguments for non-optional children (same logic as in __init__)
        constructor_args, constructor_containers = _find_non_optional_subtree(s, spath, node, ["self"], local_prefix="")
        if constructor_args:
            # Add variable declarations in reverse order to ensure dependencies are declared before use.
            # For example, if container C needs argument from container B, which needs argument from A,
            # we must generate: A_var = ..., B_var = ..., C_var = ... in that order.
            # Since find_non_optional_subtree() builds the list depth-first, we reverse it.
            res.extend(list(reversed(constructor_containers)))
            args_str = ", ".join(constructor_args)
            res.append("{self_name} = {pname(spath)}({args_str})")
        else:
            res.append("{self_name} = {pname(spath)}()")
    leaves = []
    for child in s.children:
        # Only process data nodes
        if not (isinstance(child, yschema.DNodeLeaf) or isinstance(child, yschema.DContainer) or isinstance(child, yschema.DList)):
            continue

        def path_with_child(k=None):
            return spath + [PathElement(child, k)]

        if isinstance(child, yschema.DLeaf):
            if usname(child) in create_consumed_leaves:
                continue
            if not top and not yschema.is_optional_arg_yang_leaf(child, yschema.list_keys(s), loose):
                # Do not print non-optional leafs if not top level, because
                # they are implicitly set with .create*()
                continue
            leaf = node.get_opt_leaf_or_absent(fqname(child))
            if isinstance(leaf, ygdata.Leaf):
                # DLeaf values are copied verbatim
                leaves.append("{self_name}.{usname(child)} = {repr_adata(leaf.val)}")
            elif isinstance(leaf, ygdata.Absent):
                # "leaf": Absent() is a remove op on an empty leaf
                leaves.append("{self_name}.{usname(child)} = False")
        elif isinstance(child, yschema.DLeafList):
            leaflist = node.get_opt_leaflist(fqname(child))
            if leaflist is not None:
                # DLeafList values are copied verbatim
                vals = [repr_adata(e.val) for e in leaflist.entries if isinstance(e, ygdata.LeafListEntryMerge)]
                leaves.append("{self_name}.{usname(child)} = [{", ".join(vals)}]")
        elif isinstance(child, yschema.DContainer):
            container = node.get_opt_cnt(fqname(child))
            if container is not None:
                if child.presence:
                    res.append("")
                    res.append("# P-container: {format_schema_path(path_with_child())}")
                    # Build .pradata() code for this P-container
                    pc_args, pc_var_declarations = _find_non_optional_subtree(child, path_with_child(), container, [usname(child)])
                    pc_opt_leaf_args, pc_consumed_leaf_args = _find_direct_optional_leaf_create_args(child, container)

                    # Add variable declarations in reverse order to ensure the prerequisites are met
                    res.extend(list(reversed(pc_var_declarations)))

                    child_var = path_local_var(pname(path_with_child()), usname(child))
                    pc_args_str = ", ".join(pc_args + pc_opt_leaf_args)
                    res.append("{child_var} = {self_name}.create_{usname(child)}({pc_args_str})")
                    # Recursive call to pradata() for the P-container, to fill in the rest of the optional children
                    res.extend(_pradata_recursive(child, container, child_var, loose, root_path=root_path, spath=path_with_child(), path_var_names=path_var_names, reserved_names=reserved_names, create_consumed_leaves=pc_consumed_leaf_args).splitlines())
                else:
                    res.extend(_pradata_recursive(child, container, "{self_name}.{usname(child)}", loose, root_path=root_path, spath=path_with_child(), path_var_names=path_var_names, reserved_names=reserved_names).splitlines())
        elif isinstance(child, yschema.DList):
            glist = node.get_opt_list(fqname(child))
            if glist is not None:
                list_path_key = pname(path_with_child())
                list_element_var = path_local_var(list_path_key, "{usname(child)}_element")
                for element in glist.elements:
                    res.append("")
                    res.append("# List {format_schema_path(path_with_child())} element: {element.key_str(fq_list_keys(child))}")

                    # Build the list of arguments for create() method
                    non_optional_args, non_optional_containers = _find_non_optional_subtree(child, path_with_child(), element, ["element"])
                    list_opt_leaf_args, list_consumed_leaf_args = _find_direct_optional_leaf_create_args(child, element)

                    res.extend(list(reversed(non_optional_containers)))

                    create_args_str = ", ".join(non_optional_args + list_opt_leaf_args)
                    res.append("{list_element_var} = {self_name}.{usname(child)}.create({create_args_str})")
                    # Recursive call to pradata() for the list element
                    res.extend(_pradata_recursive(child, element, list_element_var, loose, list_element=True, root_path=root_path, spath=path_with_child(element.key_values(fq_list_keys(child))), path_var_names=path_var_names, reserved_names=reserved_names, create_consumed_leaves=list_consumed_leaf_args).splitlines())
        else:
            raise ValueError("Unhandled child type in .pradata() at {format_schema_path(path_with_child())}: {type(child)}")

    # Add the leaves as a single group at the beginning of the section,
    # optionally add container header if we're not printing a list element
    if leaves:
        if top:
            res = res + leaves
        elif not list_element:
            res = ["", "# Container: {format_schema_path(spath)}"] + leaves + res
        else:
            res = leaves + res
    return "\n".join(res)


def prpaths(root: yschema.DRoot, node: ygdata.Node) -> list[str]:
    """Print value-holding schema paths in provided gdata

    Paths are rendered with yang.schema.get_path() and include only:
    - DLeaf
    - DLeafList
    - presence DContainer (only when no child value nodes are set)
    """
    out: list[str] = []
    _prpaths_recursive(root, node, [root], set(), out)
    return out


def _prpaths_recursive(s: yschema.DNodeInner, node: ygdata.Node, spath: list[yschema.DNode], seen_paths: set[str], out: list[str]) -> bool:
    """Recursive counterpart for prpaths using data-first traversal.

    The main difference from the schema-first approach used in pradata is that
    with data-first we fetch the schema nodes using the names from gdata. This
    makes it more efficient for large, sparsely populated schemas.

    Returns True if this subtree contains any emitted value path; callers use
    this to emit a presence-container path only when no child value paths exist.
    """
    def emit_path(path: list[yschema.DNode]) -> None:
        p = yschema.get_path(path)
        if p not in seen_paths:
            seen_paths.add(p)
            out.append(p)

    if not isinstance(node, ygdata.Container):
        return False

    has_value_nodes = False

    for gname in ygdata.hack_sorted(node.children.keys()):
        gchild = node.children[gname]
        try:
            if gname.q != "":
                schild = s.get(gname.name, namespace=gname.q, allow_unqualified=False)
            else:
                schild = s.get(gname.name)
        except ValueError:
            # Ignore gdata children not found in this schema subtree?!
            continue
        else:
            child_spath = spath + [schild]

            if isinstance(schild, yschema.DLeaf):
                if isinstance(gchild, ygdata.Leaf) or isinstance(gchild, ygdata.Absent):
                    emit_path(child_spath)
                    has_value_nodes = True
            elif isinstance(schild, yschema.DLeafList):
                if isinstance(gchild, ygdata.LeafList):
                    emit_path(child_spath)
                    has_value_nodes = True
            elif isinstance(schild, yschema.DContainer):
                if isinstance(gchild, ygdata.Container):
                    child_has_values = _prpaths_recursive(schild, gchild, child_spath, seen_paths, out)
                    if schild.presence and not child_has_values:
                        emit_path(child_spath)
                    has_value_nodes = True
            elif isinstance(schild, yschema.DList):
                if isinstance(gchild, ygdata.List):
                    for element in gchild.elements:
                        if isinstance(element, ygdata.Container):
                            if _prpaths_recursive(schild, element, child_spath, seen_paths, out):
                                has_value_nodes = True

    return has_value_nodes



def _test_format_schema_path_empty():
    """format_schema_path renders empty as ''"""
    path: list[PathElement] = []
    out = format_schema_path(path)
    if out != "":
        testing.error("Unexpected path: {out}")


def _test_format_schema_path_root():
    """format_schema_path renders root as '/'"""
    path: list[PathElement] = [PathElement(yschema.DRoot())]
    out = format_schema_path(path)
    if out != "/":
        testing.error("Unexpected path: {out}")


def _test_format_schema_path_list_predicate():
    """format_schema_path renders list key predicate"""
    y1 = r"""module y1 {
  namespace "urn:example:y1";
  prefix y1;

  container c {
    list l {
      key "k1 k2";
      leaf k1 { type string; }
      leaf k2 { type int32; }
      leaf v { type string; }
    }
  }
}"""

    s = yang.compile([y1])
    # Locate nodes using schema get()
    cnode = s.get("c")
    lnode = cnode.get("l")
    vnode = lnode.get("v")

    path = [PathElement(s), PathElement(cnode), PathElement(lnode, keys={"k1": "Key 1", "k2": 1}), PathElement(vnode)]
    out = format_schema_path(path)
    testing.assertEqual("/c/l[k1='Key 1',k2='1']/v", out)

    path = [PathElement(s), PathElement(cnode), PathElement(lnode, keys={"k1": "Key 1, with extra's", "k2": 1}), PathElement(vnode)]
    out = format_schema_path(path)
    testing.assertEqual(r"""/c/l[k1='Key 1, with extra\'s',k2='1']/v""", out)


def _src_yang():
    return r"""module test {
      namespace "urn:example:test";
      prefix test;

      leaf top-level-leaf {
        type string;
        description "A leaf at the module root level";
      }

      container c1 {
        leaf optional-leaf {
          type int32;
        }
        leaf empty-yes {
          type empty;
        }
        leaf empty-no {
          type empty;
        }
        leaf decimal {
          type decimal64 {
            fraction-digits 2;
          }
        }
        container c2 {
          presence "This is a presence container";
          leaf l1 {
            type string;
          }
          leaf mandatory-leaf {
            type string;
            mandatory true;
          }
        }
        container c4 {
          presence "This is an empty presence container";
          leaf l4 {
            type string;
          }
        }
        list li1 {
          key "name extra-key";
          leaf name {
            type string;
          }
          leaf extra-key {
            type int32;
          }
          leaf value {
            type int32;
          }
          container c3 {
            leaf nested-leaf {
              type string;
            }
          }
        }
        leaf-list always-empty {
          // Leave this empty, we check that empty leaf-list is not printed
          type string;
        }
      }
    }"""


def _test_pradata():
    s = yang.compile([_src_yang()])

    gdata_tree = ygdata.Container({
        ygdata.Id("urn:example:test", "top-level-leaf"): ygdata.Leaf("root value"),
        ygdata.Id("urn:example:test", "c1"): ygdata.Container({
            ygdata.Id("urn:example:test", "optional-leaf"): ygdata.Leaf(int(42)),
            ygdata.Id("urn:example:test", "empty-yes"): ygdata.Leaf(ygdata.Present()),
            ygdata.Id("urn:example:test", "empty-no"): ygdata.Absent(),
            ygdata.Id("urn:example:test", "decimal"): ygdata.Leaf(Decimal(314, -2)),
            ygdata.Id("urn:example:test", "c2"): ygdata.Container({
                ygdata.Id("urn:example:test", "l1"): ygdata.Leaf("inner value"),
                ygdata.Id("urn:example:test", "mandatory-leaf"): ygdata.Leaf("required value")
            }, presence=True),
            ygdata.Id("urn:example:test", "li1"): ygdata.List([ygdata.Id("urn:example:test", "name"), ygdata.Id("urn:example:test", "extra-key")], [
                ygdata.Container({
                    ygdata.Id("urn:example:test", "name"): ygdata.Leaf("item1"),
                    ygdata.Id("urn:example:test", "extra-key"): ygdata.Leaf(int(1)),
                    ygdata.Id("urn:example:test", "value"): ygdata.Leaf(int(100))
                }),
                ygdata.Container({
                    ygdata.Id("urn:example:test", "name"): ygdata.Leaf("item2"),
                    ygdata.Id("urn:example:test", "extra-key"): ygdata.Leaf(int(2)),
                    ygdata.Id("urn:example:test", "value"): ygdata.Leaf(int(200)),
                    ygdata.Id("urn:example:test", "c3"): ygdata.Container({
                        ygdata.Id("urn:example:test", "nested-leaf"): ygdata.Leaf("birb")
                    })
                })
            ])
        })
    })

    result = pradata(s, gdata_tree)
    return result

def _test_pradata_overlap():
    schema_str = r"""module test {
  namespace "urn:example:test";
  prefix test;

  container c1 {
    presence p;
    list l1 {
      key k1;
      leaf k1 {
        type string;
      }
    }
    container c1 {
      presence p;
      list l1 {
        key k1;
        leaf k1 {
          type string;
        }
      }
    }
    container a {
      container b {
        leaf value {
          type string;
          mandatory true;
        }
      }
    }
    container a-b {
      leaf value {
        type string;
        mandatory true;
      }
    }
  }
}"""

    s = yang.compile([schema_str])

    gdata_tree = ygdata.Container({
        ygdata.Id("urn:example:test", "c1"): ygdata.Container({
            ygdata.Id("urn:example:test", "l1"): ygdata.List([ygdata.Id("urn:example:test", "kl1")], [
                ygdata.Container({
                    ygdata.Id("urn:example:test", "kl1"): ygdata.Leaf("outer-1"),
                    ygdata.Id("urn:example:test", "k1"): ygdata.Leaf("outer-1")
                }),
                ygdata.Container({
                    ygdata.Id("urn:example:test", "kl1"): ygdata.Leaf("outer-2"),
                    ygdata.Id("urn:example:test", "k1"): ygdata.Leaf("outer-2")
                })
            ]),
            ygdata.Id("urn:example:test", "c1"): ygdata.Container({
                ygdata.Id("urn:example:test", "l1"): ygdata.List([ygdata.Id("urn:example:test", "kl1")], [
                    ygdata.Container({
                        ygdata.Id("urn:example:test", "kl1"): ygdata.Leaf("inner-1"),
                        ygdata.Id("urn:example:test", "k1"): ygdata.Leaf("inner-1")
                    })
                ])
            }),
            ygdata.Id("urn:example:test", "a"): ygdata.Container({
                ygdata.Id("urn:example:test", "b"): ygdata.Container({
                    ygdata.Id("urn:example:test", "value"): ygdata.Leaf("inner")
                })
            }),
            ygdata.Id("urn:example:test", "a-b"): ygdata.Container({
                ygdata.Id("urn:example:test", "value"): ygdata.Leaf("flat")
            })
        })
    })

    result = pradata(s, gdata_tree)
    return result


def _test_pradata_root_path():
    schema_str = r"""module test {
      namespace "urn:example:test";
      prefix test;

      container outer {
        container middle {
          leaf value1 {
            type string;
          }
          container inner {
            leaf value2 {
              type int32;
            }
          }
        }
      }
    }"""

    s = yang.compile([schema_str])

    gdata_tree = ygdata.Container({
        ygdata.Id("urn:example:test", "outer"): ygdata.Container({
            ygdata.Id("urn:example:test", "middle"): ygdata.Container({
                ygdata.Id("urn:example:test", "value1"): ygdata.Leaf("test value"),
                ygdata.Id("urn:example:test", "inner"): ygdata.Container({
                    ygdata.Id("urn:example:test", "value2"): ygdata.Leaf(int(42))
                })
            })
        })
    })

    middle_node = gdata_tree.get_cnt(ygdata.Id("urn:example:test", "outer")).get_cnt(ygdata.Id("urn:example:test", "middle"))
    result = pradata(s, middle_node, root_path=["test:outer", "middle"])

    return result


def _test_prpaths():
    s = yang.compile([_src_yang()])

    gdata_tree = ygdata.Container({
        ygdata.Id("urn:example:test", "top-level-leaf"): ygdata.Leaf("root value"),
        ygdata.Id("urn:example:test", "c1"): ygdata.Container({
            ygdata.Id("urn:example:test", "c2"): ygdata.Container({
                ygdata.Id("urn:example:test", "mandatory-leaf"): ygdata.Leaf("required value")
            }, presence=True),
            ygdata.Id("urn:example:test", "c4"): ygdata.Container({}, presence=True),
            ygdata.Id("urn:example:test", "li1"): ygdata.List([ygdata.Id("urn:example:test", "name"), ygdata.Id("urn:example:test", "extra-key")], [
                ygdata.Container({
                    ygdata.Id("urn:example:test", "name"): ygdata.Leaf("item1"),
                    ygdata.Id("urn:example:test", "extra-key"): ygdata.Leaf(int(1)),
                    ygdata.Id("urn:example:test", "value"): ygdata.Leaf(int(100))
                }),
                ygdata.Container({
                    ygdata.Id("urn:example:test", "name"): ygdata.Leaf("item2"),
                    ygdata.Id("urn:example:test", "extra-key"): ygdata.Leaf(int(2)),
                    ygdata.Id("urn:example:test", "value"): ygdata.Leaf(int(200)),
                    ygdata.Id("urn:example:test", "c3"): ygdata.Container({
                        ygdata.Id("urn:example:test", "nested-leaf"): ygdata.Leaf("birb")
                    })
                })
            ])
        })
    })

    result = prpaths(s, gdata_tree)
    return "\n".join(result)
